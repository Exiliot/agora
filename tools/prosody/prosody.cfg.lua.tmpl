-- Prosody config template for the agora Phase 2 federation demo.
-- @@DOMAIN@@, @@MUC_DOMAIN@@, @@AUTH_URL@@ substituted by entrypoint.sh.

admins = { }

plugin_paths = { "/usr/lib/prosody/modules-community" }

modules_enabled = {
  "roster";
  "saslauth";
  "dialback";       -- XEP-0220: server-to-server auth via DNS, no certs
  "disco";
  "private";
  "vcard";
  "version";
  "uptime";
  "time";
  "ping";
  "admin_adhoc";
  "auth_http";      -- community module: POSTs credentials to agora
  -- 'muc' loads only as a Component (below), not as a global module.
}

modules_disabled = { }

-- HTTP auth plugin: POST JSON {"user":..., "pass":...} to the URL,
-- expect HTTP 200 on success, any non-2xx on failure.
http_auth_url = "@@AUTH_URL@@"

-- s2s: dialback-only, plaintext on the demo compose network.
-- c2s: STARTTLS offered via self-signed cert so SASL PLAIN can proceed
-- (xmpp.js clients require TLS before PLAIN by default).
s2s_require_encryption = false
s2s_secure_auth = false
c2s_require_encryption = true

authentication = "http"

allow_registration = false

interfaces = { "*" }
c2s_ports = { 5222 }
s2s_ports = { 5269 }
-- Direct-TLS c2s on 5223: skips STARTTLS negotiation, XMPP clients connect
-- with TLS already established. Gives xmpp.js a predictable SASL context.
c2s_direct_tls_ports = { 5223 }

log = {
  { levels = { min = "debug" }, to = "console" };
}

pidfile = "/var/run/prosody/prosody.pid"
data_path = "/var/lib/prosody"

-- Certs generated by the entrypoint. Self-signed; demo-only.
ssl = {
  certificate = "/var/lib/prosody/certs/@@DOMAIN@@.crt";
  key = "/var/lib/prosody/certs/@@DOMAIN@@.key";
}

-- This server's domain (set per-instance).
VirtualHost "@@DOMAIN@@"
  authentication = "http"
  ssl = {
    certificate = "/var/lib/prosody/certs/@@DOMAIN@@.crt";
    key = "/var/lib/prosody/certs/@@DOMAIN@@.key";
  }

-- MUC component for this server.
Component "@@MUC_DOMAIN@@" "muc"
  restrict_room_creation = false
